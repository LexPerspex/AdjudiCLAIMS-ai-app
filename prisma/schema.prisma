// =============================================================================
// AdjudiCLAIMS Prisma Schema
// =============================================================================
// CA Workers' Compensation claims management AI platform.
// Phase 2A standalone deployment — no shared claims with attorney product.
//
// Database: PlanetScale (MySQL/Vitess)
// ORM: Prisma 6
// Multi-tenancy: Organization-scoped (CARRIER, TPA, SELF_INSURED)
// Vector search: Vertex AI Vector Search (Voyage Large embeddings)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// =============================================================================
// Enums
// =============================================================================

enum OrganizationType {
  CARRIER
  TPA
  SELF_INSURED

  @@map("organization_type")
}

enum UserRole {
  CLAIMS_ADMIN
  CLAIMS_SUPERVISOR
  CLAIMS_EXAMINER

  @@map("user_role")
}

enum ClaimStatus {
  OPEN
  UNDER_INVESTIGATION
  ACCEPTED
  DENIED
  CLOSED
  REOPENED

  @@map("claim_status")
}

enum DocumentType {
