/// Generated correspondence letter — benefit explanations, employer notifications, etc.
model GeneratedLetter {
  id            String     @id @default(cuid()) @map("id")
  claimId       String     @map("claim_id")
  userId        String     @map("user_id")
  letterType    LetterType @map("letter_type")
  content       String     @map("content") @db.LongText
  templateId    String     @map("template_id")
  populatedData Json       @map("populated_data")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  claim Claim @relation(fields: [claimId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([claimId, letterType], map: "idx_generated_letters_claim_type")
  @@index([userId], map: "idx_generated_letters_user_id")
  @@map("generated_letters")
}

/// Tracked counsel referral — factual summary + status + defense counsel response.
model CounselReferral {
  id              String         @id @default(cuid()) @map("id")
  claimId         String         @map("claim_id")
  userId          String         @map("user_id")
  legalIssue      String         @map("legal_issue")
  summary         String         @map("summary") @db.Text
  status          ReferralStatus @default(PENDING) @map("status")
  counselEmail    String?        @map("counsel_email")
  counselResponse String?        @map("counsel_response")
  respondedAt     DateTime?      @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  claim Claim @relation(fields: [claimId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([claimId, status], map: "idx_counsel_referrals_claim_status")
  @@index([userId], map: "idx_counsel_referrals_user_id")
  @@map("counsel_referrals")
}

/// Lien filed against a workers' compensation claim.
model Lien {
  id                  String          @id @default(cuid()) @map("id")
  claimId             String          @map("claim_id")
  lienClaimant        String          @map("lien_claimant")
  lienType            LienType        @map("lien_type")
  totalAmountClaimed  Decimal         @map("total_amount_claimed") @db.Decimal(12, 2)
  totalOmfsAllowed    Decimal?        @map("total_omfs_allowed") @db.Decimal(12, 2)
  discrepancyAmount   Decimal?        @map("discrepancy_amount") @db.Decimal(12, 2)
  filingDate          DateTime        @map("filing_date") @db.Date
  filingFeeStatus     FilingFeeStatus @default(UNKNOWN) @map("filing_fee_status")
  status              LienStatus      @default(RECEIVED) @map("status")
  resolvedAmount      Decimal?        @map("resolved_amount") @db.Decimal(12, 2)
  resolvedAt          DateTime?       @map("resolved_at")
  wcabCaseNumber      String?         @map("wcab_case_number")
  notes               String?         @map("notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  claim     Claim          @relation(fields: [claimId], references: [id])
  lineItems LienLineItem[]

  @@index([claimId, status], map: "idx_liens_claim_status")
  @@index([lienType], map: "idx_liens_lien_type")
  @@index([status], map: "idx_liens_status")
  @@map("liens")
}

/// Individual line item on a lien — with OMFS fee schedule comparison.
model LienLineItem {
  id              String   @id @default(cuid()) @map("id")
  lienId          String   @map("lien_id")
  serviceDate     DateTime @map("service_date") @db.Date
  cptCode         String?  @map("cpt_code")
  description     String   @map("description")
  amountClaimed   Decimal  @map("amount_claimed") @db.Decimal(10, 2)
  omfsRate        Decimal? @map("omfs_rate") @db.Decimal(10, 2)
  isOvercharge    Boolean  @default(false) @map("is_overcharge")
  overchargeAmount Decimal? @map("overcharge_amount") @db.Decimal(10, 2)

  // Relations
  lien Lien @relation(fields: [lienId], references: [id], onDelete: Cascade)

  @@index([lienId], map: "idx_lien_line_items_lien_id")
  @@index([cptCode], map: "idx_lien_line_items_cpt_code")
  @@map("lien_line_items")
}

// =============================================================================
// Graph RAG Models
// =============================================================================

/// Per-claim graph node — entities extracted from documents.
/// Nodes are scoped to a single claim and typed by the 13-value ontology.
model GraphNode {
  id              String        @id @default(cuid()) @map("id")
  claimId         String        @map("claim_id")
  nodeType        GraphNodeType @map("node_type")
  canonicalName   String        @map("canonical_name") @db.VarChar(500)
  aliases         Json          @default("[]") @map("aliases")
  properties      Json          @default("{}") @map("properties")

  // Person/Org subtype (stored as JSON since PersonRole/OrgType are domain-specific)
  personRole      PersonRole?   @map("person_role")
  orgType         OrgType?      @map("org_type")

  // Provenance
  sourceDocumentIds Json        @default("[]") @map("source_document_ids")
  confidence        Float       @default(0) @map("confidence")

  // Embedding (model-agnostic — dimension stored per-model, not per-schema)
  embeddingModel  String?       @map("embedding_model")

  // Human verification
  humanVerified   Boolean       @default(false) @map("human_verified")
  humanVerifiedBy String?       @map("human_verified_by")
  locked          Boolean       @default(false) @map("locked")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  claim         Claim       @relation(fields: [claimId], references: [id])
  outgoingEdges GraphEdge[] @relation("EdgeSource")
  incomingEdges GraphEdge[] @relation("EdgeTarget")

  @@index([claimId, nodeType], map: "idx_graph_nodes_claim_type")
  @@index([claimId, canonicalName], map: "idx_graph_nodes_claim_name")
  @@index([nodeType], map: "idx_graph_nodes_type")
  @@map("graph_nodes")
}

/// Per-claim graph edge — relationships between nodes with neuro-plastic properties.
/// Edges carry provenance, confidence (Noisy-OR), contradiction state, and traversal stats.
model GraphEdge {
  id           String        @id @default(cuid()) @map("id")
  claimId      String        @map("claim_id")
  edgeType     GraphEdgeType @map("edge_type")
  sourceNodeId String        @map("source_node_id")
  targetNodeId String        @map("target_node_id")
  properties   Json          @default("{}") @map("properties")

  // Provenance
  sourceDocumentIds Json @default("[]") @map("source_document_ids")
  sourceChunkIds    Json @default("[]") @map("source_chunk_ids")

  // Confidence (Noisy-OR across sources)
  confidence        Float @default(0) @map("confidence")
  sourceConfidences Json  @default("[]") @map("source_confidences")

  // Neuro-plastic weight (Hebbian strengthening / lazy decay)
  weight          Float    @default(1.0) @map("weight")
  traversalCount  Int      @default(0) @map("traversal_count")
  lastTraversedAt DateTime? @map("last_traversed_at")

  // Contradiction tracking
  contradictionStatus    ContradictionStatus @default(NONE) @map("contradiction_status")
  contradictedByEdgeIds  Json                @default("[]") @map("contradicted_by_edge_ids")
  contradictionType      String?             @map("contradiction_type")

  // Human verification
  humanVerified   Boolean  @default(false) @map("human_verified")
  humanVerifiedBy String?  @map("human_verified_by")
  locked          Boolean  @default(false) @map("locked")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  claim      Claim     @relation(fields: [claimId], references: [id])
  sourceNode GraphNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  targetNode GraphNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([claimId, edgeType], map: "idx_graph_edges_claim_type")
  @@index([sourceNodeId], map: "idx_graph_edges_source")
  @@index([targetNodeId], map: "idx_graph_edges_target")
  @@index([claimId, weight], map: "idx_graph_edges_claim_weight")
  @@index([contradictionStatus], map: "idx_graph_edges_contradiction")
  @@map("graph_edges")
}

/// Subgraph summary — consolidated natural language summary of a node cluster.
model GraphSummary {
  id       String  @id @default(cuid()) @map("id")
  claimId  String  @map("claim_id")
  nodeIds  Json    @default("[]") @map("node_ids")
  edgeIds  Json    @default("[]") @map("edge_ids")
  summary  String  @map("summary") @db.Text
  isValid  Boolean @default(true) @map("is_valid")

  // Embedding
  embeddingModel String? @map("embedding_model")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId], map: "idx_graph_summaries_claim")
  @@map("graph_summaries")
}

/// Per-claim graph maturity — 5 examiner facets tracking enrichment completeness.
model GraphMaturity {
  id      String @id @default(cuid()) @map("id")
  claimId String @unique @map("claim_id")

  overallScore          Float        @default(0) @map("overall_score")
  medicalScore          Float        @default(0) @map("medical_score")
  insuranceBenefitScore Float        @default(0) @map("insurance_benefit_score")
  employmentScore       Float        @default(0) @map("employment_score")
  regulatoryScore       Float        @default(0) @map("regulatory_score")
  evidentialScore       Float        @default(0) @map("evidential_score")
  maturityLabel         MaturityLabel @default(NASCENT) @map("maturity_label")

  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  claim Claim @relation(fields: [claimId], references: [id])

  @@map("graph_maturity")
}

/// Tracks property changes on graph nodes for audit/timeline purposes.
model GraphStatusChange {
  id            String   @id @default(cuid()) @map("id")
  claimId       String   @map("claim_id")
  targetNodeId  String   @map("target_node_id")
  field         String   @map("field")
  oldValue      String?  @map("old_value") @db.Text
  newValue      String?  @map("new_value") @db.Text
  effectiveDate DateTime? @map("effective_date")
  documentId    String?  @map("document_id")
  confidence    Float    @default(0) @map("confidence")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId], map: "idx_graph_status_changes_claim")
  @@index([targetNodeId], map: "idx_graph_status_changes_node")
  @@map("graph_status_changes")
}

/// Cognitive router query signal — tracks how graph queries are routed and whether they succeeded.
model GraphQuerySignal {
  id              String   @id @default(cuid()) @map("id")
  claimId         String   @map("claim_id")
  queryText       String   @map("query_text") @db.Text
  queryPattern    String?  @map("query_pattern")
  observeSnapshot Json?    @map("observe_snapshot")
  tierSelected    String?  @map("tier_selected")
  tierUsed        String?  @map("tier_used")
  escalated       Boolean  @default(false) @map("escalated")
  iscDriftScore   Float?   @map("isc_drift_score")
  succeeded       Boolean? @map("succeeded")
  latencyMs       Int?     @map("latency_ms")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId], map: "idx_graph_query_signals_claim")
  @@index([queryPattern], map: "idx_graph_query_signals_pattern")
  @@map("graph_query_signals")
}
