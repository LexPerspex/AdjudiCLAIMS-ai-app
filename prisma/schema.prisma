  MEDICAL_REPORT
  BILLING_STATEMENT
  LEGAL_CORRESPONDENCE
  EMPLOYER_REPORT
  INVESTIGATION_REPORT
  UTILIZATION_REVIEW
  AME_QME_REPORT
  DEPOSITION_TRANSCRIPT
  IMAGING_REPORT
  PHARMACY_RECORD
  WAGE_STATEMENT
  BENEFIT_NOTICE
  SETTLEMENT_DOCUMENT
  CORRESPONDENCE
  OTHER
  WCAB_FILING
  LIEN_CLAIM
  DISCOVERY_REQUEST
  RETURN_TO_WORK
  PAYMENT_RECORD
  DWC_OFFICIAL_FORM
  WORK_PRODUCT
  MEDICAL_CHRONOLOGY
  CLAIM_ADMINISTRATION

